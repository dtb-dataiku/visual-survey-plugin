// This file is the descriptor for webapp webapp
{
    "meta": {
        "label": "Survey",
        "description": "",
        "icon": "fas fa-poll"
    },

    "baseType": "DASH", // WARNING: do not change
    "hasBackend": "true",
    "noJSSecurity": "true",
    "standardWebAppLibraries": null,
    "hideWebAppConfig": "true",

    /* The field "params" holds a list of all the params
       for wich the user will be prompted for values in the Settings tab of the webapp.

       The available parameter types include:
       STRING, STRINGS, INT, DOUBLE, BOOLEAN, SELECT, MULTISELECT, MAP, TEXTAREA, PRESET, DATASET, DATASET_COLUMN, MANAGED_FOLDER

       For the full list and for more details, see the documentation: https://doc.dataiku.com/dss/latest/plugins/reference/params.html
    */
    "params": [
        {
            "name": "setup-section",
            "label": "Survey",
            "type": "SEPARATOR"
        },
        {
            "name": "survey_header",
            "type": "STRING",
            "label": "Name",
            "description": "Enter short name for the survey",
            "mandatory": true
        },
        {
            "name": "survey_subheader",
            "type": "STRING",
            "label": "Description",
            "description": "Enter short description for the survey",
            "mandatory": true
        },
        {
            "type": "SEPARATOR",
            "label": "Questions"
        },
        {
            "name": "question_dataset",
            "type": "DATASET",
            "label": "Dataset",
            "description": "Select a dataset containing questions for survey",
            "mandatory": true
        },
        {
            "name": "type_column",
            "type": "DATASET_COLUMN",
            "label": "Type",
            "description": "Select column containing the type of question",
            "datasetParamName": "question_dataset",
            "mandatory": true
        },
        {
            "name": "name_column",
            "type": "DATASET_COLUMN",
            "label": "Name",
            "description": "Select column containing a short name for the questions",
            "datasetParamName": "question_dataset",
            "mandatory": true
        },
        {
            "name": "question_column",
            "type": "DATASET_COLUMN",
            "label": "Question",
            "description": "Select column containing the question",
            "datasetParamName": "question_dataset",
            "mandatory": true
        },
        {
            "name": "options_column",
            "type": "DATASET_COLUMN",
            "label": "Options",
            "description": "Select column containing the options for the questions",
            "datasetParamName": "question_dataset",
            "mandatory": true
        },
        {
            "name": "default_option_column",
            "type": "DATASET_COLUMN",
            "label": "Default Option",
            "description": "Select column containing the default option for the questions",
            "datasetParamName": "question_dataset",
            "mandatory": true
        },
        {
            "name": "display_column",
            "type": "DATASET_COLUMN",
            "label": "Display Name",
            "description": "Select column containing display name for rank options",
            "datasetParamName": "question_dataset",
            "mandatory": true
        },
        {
            "type": "SEPARATOR",
            "label": "Responses"
        },
        {
            "name": "folder_name",
            "type": "MANAGED_FOLDER",
            "label": "Folder",
            "description": "Select a folder to store survey responses",
            "mandatory": true
        },
        {
            "name": "anonymous",
            "type": "BOOLEAN",
            "label": "Anonymous",
            "description": "Anonymize the responses",
            "defaultValue": false
        }
    ],
    "roles": []
}
